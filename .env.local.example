# Supabase — get these from your Supabase project settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Google Places API — for review link generator
GOOGLE_PLACES_API_KEY=your-google-places-api-key

# Vercel — for custom domain management
# Get from: https://vercel.com/account/tokens
VERCEL_TOKEN=your-vercel-api-token
# Get from: Vercel project settings > General > Project ID
VERCEL_PROJECT_ID=your-vercel-project-id
# Optional — only needed if using a Vercel team
VERCEL_TEAM_ID=

# Stripe — subscription billing
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Get from: Stripe Dashboard > Webhooks > Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...
# Price IDs — create products in Stripe Dashboard > Product catalog
STRIPE_PRICE_SITES_PRO=price_...
STRIPE_PRICE_TOOLS=price_...
STRIPE_PRICE_AI=price_...
